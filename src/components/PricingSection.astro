---
---
<section id="pricing" class="max-w-7xl mx-auto px-6 mb-20 relative pt-12 pb-8">
  <!-- Decorative Frame Background (Around the whole section) -->
  <div class="absolute inset-0 border-4 border-black bg-white translate-x-3 translate-y-3 -z-20 shadow-hard" style="width: 100%; height: 100%;"></div>
  <div class="absolute inset-0 border-4 border-black bg-comic-blue opacity-20 -translate-x-2 -translate-y-2 -z-30" style="width: 100%; height: 100%;"></div>

  <div class="mb-12 text-center relative z-10">

    
    <!-- Main Title -->
    <h2 class="text-3xl md:text-5xl lg:text-6xl font-black uppercase mb-4 leading-none transform -rotate-1 hover:rotate-2 hover:scale-105 transition-transform duration-300 inline-block cursor-default bg-white px-4 py-2 border-4 border-black shadow-hard-sm">
      <span data-i18n="pricing.title">Paket Website UMKM</span>
    </h2>
    
    <!-- Hook Subtitle -->
    <p class="text-lg md:text-xl font-bold text-black max-w-3xl mx-auto mt-4 bg-comic-yellow p-3 border-2 border-black inline-block rotate-1 hover:rotate-0 transition-transform" data-i18n="pricing.hook">
      "Bisnis tanpa website = Toko tanpa alamat. Saatnya go digital!"
    </p>
    
    <!-- Supporting Text -->
    <p class="text-base md:text-lg font-medium text-gray-600 max-w-2xl mx-auto mt-4" data-i18n="pricing.desc">
      Harga transparan. Tanpa biaya tersembunyi. Hasil profesional dalam 3-30 hari kerja.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
    <!-- PAKET 1: SATSET -->
    <div class="group relative bg-white border-4 border-black shadow-hard hover:shadow-[16px_16px_0px_0px_#2563eb] transition-all duration-300 transform hover:-translate-y-2 hover:-rotate-1 hover:scale-105 flex flex-col z-10 hover:z-50">
      <div class="bg-blue-600 p-6 border-b-4 border-black relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/black-scales.png')] opacity-20 group-hover:opacity-40 transition-opacity"></div>
         <!-- Animated Badge -->
         <div class="absolute -top-12 -right-12 bg-yellow-400 w-24 h-24 rotate-45 border-4 border-black group-hover:translate-y-2 group-hover:-translate-x-2 transition-transform duration-500"></div>

        <div class="relative z-10 group-hover:translate-x-1 transition-transform">
          <h3 class="text-3xl font-black text-white uppercase italic drop-shadow-md" data-i18n="pricing.packet1.name">Starter "Satset"</h3>
          <p class="text-white font-bold opacity-90">Company Profile & Branding</p>
        </div>
      </div>
      
      <div class="p-8 flex-1 flex flex-col relative overflow-hidden">
         <!-- Flying Icons on hover -->
         <div class="absolute -right-8 top-16 opacity-0 group-hover:opacity-20 group-hover:-translate-x-4 transition-all duration-500 rotate-12 pointer-events-none">
           <span class="material-symbols-outlined text-9xl text-blue-600">rocket_launch</span>
         </div>

        <div class="mb-6 relative z-10">
          <div class="text-4xl font-black text-black group-hover:text-blue-600 transition-colors">Rp 1.500.000</div>
        </div>

        <ul class="space-y-3 mb-8 flex-1 relative z-10">
            <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-75">
              <span class="material-symbols-outlined text-blue-600 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet1.feat1">5 Halaman Company Profile</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-100">
               <span class="material-symbols-outlined text-blue-600 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet1.feat2">Gratis Domain .COM (1 Tahun)</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-150">
               <span class="material-symbols-outlined text-blue-600 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet1.feat3">Hosting Cloud Standar</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-200">
               <span class="material-symbols-outlined text-blue-600 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet1.feat4">Desain Responsif Mobile</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-300">
               <span class="material-symbols-outlined text-blue-600 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet1.feat5">Tombol WhatsApp Melayang</span>
            </li>
        </ul>

        <div class="border-t-2 border-dashed border-gray-300 pt-4 mt-auto relative z-10">
           <div class="flex justify-between items-center text-sm font-bold">
              <span>Durasi:</span>
              <span class="bg-black text-white px-2 py-1 group-hover:bg-blue-600 transition-colors">3 - 7 Hari Kerja</span>
           </div>
        </div>
      </div>
    </div>

    <!-- PAKET 2: BUSINESS SYSTEM -->
    <div class="group relative bg-white border-4 border-black shadow-hard hover:shadow-[16px_16px_0px_0px_#ea2a33] transition-all duration-300 transform hover:-translate-y-2 hover:rotate-1 hover:scale-105 flex flex-col z-10 hover:z-50">
      <div class="bg-black p-6 border-b-4 border-black relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/black-scales.png')] opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <!-- Animated Badge -->
         <div class="absolute -top-12 -right-12 bg-yellow-400 w-24 h-24 rotate-45 border-4 border-black group-hover:translate-y-2 group-hover:-translate-x-2 transition-transform duration-500 z-0"></div>

        <div class="relative z-10 group-hover:translate-x-1 transition-transform">
          <div class="absolute -top-2 -right-2 bg-yellow-400 border-2 border-black px-2 py-1 text-[10px] font-black rotate-12 shadow-sm group-hover:rotate-[360deg] transition-transform duration-700 z-20">BEST VALUE</div>
          <h3 class="text-3xl font-black text-white uppercase italic drop-shadow-md" data-i18n="pricing.packet2.name">Business "System"</h3>
          <p class="text-white font-bold opacity-90">E-Commerce / Booking</p>
        </div>
      </div>
      
      <div class="p-8 flex-1 flex flex-col relative overflow-hidden">
         <!-- Flying Icons on hover -->
         <div class="absolute -right-8 top-16 opacity-0 group-hover:opacity-20 group-hover:-translate-x-4 transition-all duration-500 -rotate-12 pointer-events-none">
            <span class="material-symbols-outlined text-9xl text-primary">shopping_cart</span>
         </div>

         <div class="mb-6 relative z-10">
          <div class="text-4xl font-black text-black group-hover:text-primary transition-colors">Rp 4.500.000</div>
        </div>

        <ul class="space-y-3 mb-8 flex-1 relative z-10">
            <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-75">
              <span class="material-symbols-outlined text-primary font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet2.feat1">Toko Online Lengkap (Katalog/Keranjang)</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-100">
              <span class="material-symbols-outlined text-primary font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet2.feat2">Payment Gateway (QRIS/VA)</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-150">
              <span class="material-symbols-outlined text-primary font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet2.feat3">Integrasi Ongkir (RajaOngkir)</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-200">
              <span class="material-symbols-outlined text-primary font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet2.feat4">Dashboard Admin</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-300">
              <span class="material-symbols-outlined text-primary font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet2.feat5">Server Performa Tinggi</span>
            </li>
        </ul>

         <div class="border-t-2 border-dashed border-gray-300 pt-4 mt-auto relative z-10">
           <div class="flex justify-between items-center text-sm font-bold">
              <span>Durasi:</span>
              <span class="bg-black text-white px-2 py-1 group-hover:bg-primary transition-colors">14 - 30 Hari Kerja</span>
           </div>
        </div>
      </div>
    </div>

    <!-- PAKET 3: CUSTOM MADE -->
    <div class="group relative bg-white border-4 border-black shadow-hard hover:shadow-[16px_16px_0px_0px_#a855f7] transition-all duration-300 transform hover:-translate-y-2 hover:-rotate-1 hover:scale-105 flex flex-col z-10 hover:z-50">
      <div class="bg-purple-700 p-6 border-b-4 border-black relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/black-scales.png')] opacity-20 group-hover:opacity-40 transition-opacity"></div>
        <!-- Animated Badge -->
         <div class="absolute -top-12 -right-12 bg-yellow-400 w-24 h-24 rotate-45 border-4 border-black group-hover:translate-y-2 group-hover:-translate-x-2 transition-transform duration-500"></div>
         
        <div class="relative z-10 group-hover:translate-x-1 transition-transform">
          <h3 class="text-3xl font-black text-white uppercase italic drop-shadow-md" data-i18n="pricing.packet3.name">Custom "Beast"</h3>
          <p class="text-white font-bold opacity-90">Enterprise & Special Needs</p>
        </div>
      </div>
      
      <div class="p-8 flex-1 flex flex-col relative overflow-hidden">
          <!-- Flying Icons on hover -->
         <div class="absolute -right-8 top-16 opacity-0 group-hover:opacity-20 group-hover:-translate-x-4 transition-all duration-500 rotate-180 pointer-events-none">
            <span class="material-symbols-outlined text-9xl text-purple-700">construction</span>
         </div>

         <div class="mb-6 relative z-10">
          <div class="text-3xl font-black text-black group-hover:text-purple-700 transition-colors">Custom Price</div>
          <p class="text-sm font-medium text-gray-500 italic mt-1">Depends on complexity</p>
        </div>

        <ul class="space-y-3 mb-8 flex-1 relative z-10">
            <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-75">
              <span class="material-symbols-outlined text-purple-700 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet3.feat1">Web App Custom / SaaS</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-100">
               <span class="material-symbols-outlined text-purple-700 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet3.feat2">Desain Database Kompleks</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-150">
               <span class="material-symbols-outlined text-purple-700 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet3.feat3">Pengembangan API</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-200">
               <span class="material-symbols-outlined text-purple-700 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet3.feat4">Arsitektur Skalabilitas Tinggi</span>
            </li>
             <li class="flex items-start gap-3 group-hover:translate-x-2 transition-transform duration-300 delay-500">
               <span class="material-symbols-outlined text-purple-700 font-black">check</span>
              <span class="font-medium text-sm" data-i18n="pricing.packet3.feat5">Dukungan Prioritas</span>
            </li>
        </ul>

         <div class="border-t-2 border-dashed border-gray-300 pt-4 mt-auto relative z-10">
            <a href="https://wa.me/6282190599569" target="_blank" class="neo-brutal-btn hover-shake block w-full text-center bg-black text-white font-bold uppercase py-3 border-2 border-transparent hover:bg-white hover:text-black hover:border-black hover:shadow-hard-sm transition-all group-hover:bg-purple-700 group-hover:text-white group-hover:border-black" data-i18n="pricing.cta">
              Pilih Paket Ini
            </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Free Consultation Hook (More Heboh) -->
  <!-- Free Consultation Hook (More Heboh) -->
  <!-- Free Consultation Hook (More Heboh) -->
  <div class="relative shadow-hard transform rotate-1 hover:rotate-0 transition-transform duration-300 group z-10 hover:z-20">
    <!-- Floating Sticker (ABSOLUTELY ON TOP) -->
    <div class="absolute -top-6 -left-6 hidden md:block animate-float-sticker z-50 pointer-events-none">
       <div class="bg-white border-4 border-black px-6 py-3 -rotate-12 shadow-md transform group-hover:scale-110 transition-transform">
          <h4 class="font-black text-3xl text-black">???</h4>
       </div>
    </div>

    <!-- Main Card Content (Clipped) -->
    <div class="bg-comic-yellow border-4 border-black p-8 relative overflow-hidden z-10">
        <!-- Moving striped background -->
        <div class="absolute inset-0 opacity-10" style="background: repeating-linear-gradient(45deg, #000, #000 10px, transparent 10px, transparent 20px);"></div>
        
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 relative z-10">
          <div class="text-center md:text-left">
            <h3 class="text-4xl md:text-5xl font-black uppercase mb-2 drop-shadow-sm group-hover:tracking-wider transition-all">Bingung?</h3>
            <p class="font-bold text-lg md:text-xl">
              Konsultasi itu <span class="bg-black text-white px-2 group-hover:bg-primary group-hover:scale-110 inline-block transition-all">GRATIS 100%</span>. 
              Yuk ngobrol dulu!
            </p>
          </div>
          <a href="https://wa.me/6282190599569" target="_blank" class="neo-brutal-btn hover-glitch bg-white text-black text-2xl font-black px-10 py-5 border-4 border-black shadow-hard-sm hover:shadow-none transition-all uppercase whitespace-nowrap flex items-center gap-3 group-hover:scale-110">
            <span>Free Consult</span>
            <span class="material-symbols-outlined font-black animate-bounce-slow">arrow_forward</span>
          </a>
        </div>

        <!-- Comic Pop Decoration -->
        <div class="absolute -bottom-10 -right-10 w-32 h-32 bg-primary rounded-full border-4 border-black hidden md:block group-hover:scale-150 transition-transform duration-500 z-0"></div>
    </div>
  </div>
</section>
