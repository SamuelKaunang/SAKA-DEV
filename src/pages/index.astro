  <script>
    // Attach listeners
    document.querySelectorAll('.view-project-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        // @ts-ignore
        const id = e.currentTarget.dataset.id;
        if (id) {
           window.dispatchEvent(new CustomEvent('open-project-modal', {
             detail: { id }
           }));
        }
      });
    });

    // About Me Modal Listener
    const aboutBtn = document.querySelector('.about-me-btn');
    if (aboutBtn) {
      aboutBtn.addEventListener('click', () => {
        window.dispatchEvent(new Event('open-about-modal'));
      });
    }

    /* --- HACKER SCRAMBLE EFFECT --- */
    const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%^&*()_+-=[]{}|;:,.<>?";

    document.querySelectorAll('[data-hacker-text]').forEach((element) => {
        const originalText = (element as HTMLElement).innerText; // Store original text
        
        element.addEventListener('mouseover', (event) => {
            let iteration = 0;
            let interval: any = null;
            const target = event.target as HTMLElement;

            clearInterval(interval);

            interval = setInterval(() => {
                target.innerText = target.innerText
                    .split("")
                    .map((_, index) => {
                        if (index < iteration) {
                            return originalText[index];
                        }
                        return letters[Math.floor(Math.random() * letters.length)];
                    })
                    .join("");

                if (iteration >= originalText.length) {
                    clearInterval(interval);
                }

                iteration += 1 / 3; // Controls the speed. Higher = faster.
            }, 30);
        });
    });
    /* --- CLICK POP EFFECT --- */
    const comicWords = ["POW!", "BAM!", "CLICK!", "BOOM!", "ZAP!", "SLAM!", "CRASH!"];
    const shapes = ["shape-burst", "shape-cloud", "shape-zap", "shape-star", "shape-box"];

    document.addEventListener('mousedown', (e) => {
        // Create element
        const pop = document.createElement('div');
        pop.classList.add('click-pop');
        
        // Randomize word
        pop.innerText = comicWords[Math.floor(Math.random() * comicWords.length)];
        
        // Randomize shape
        const randomShape = shapes[Math.floor(Math.random() * shapes.length)];
        pop.classList.add(randomShape);

        // Position at cursor
        pop.style.left = `${e.clientX}px`;
        pop.style.top = `${e.clientY}px`;

        // Random rotation for animation
        const rotation = Math.random() * 40 - 20; // -20deg to 20deg
        pop.style.setProperty('--rotation', `${rotation}deg`);
        
        // Randomize size slightly
        const scale = 0.8 + Math.random() * 0.6; // 0.8x to 1.4x
        pop.style.fontSize = `${2.5 * scale}rem`;

        document.body.appendChild(pop);

        // Cleanup
        setTimeout(() => {
            pop.remove();
        }, 600); // Match CSS animation duration


    });

    /* --- CTA 3D TILT EFFECT (OPTIMIZED) --- */
    const ctaSection = document.getElementById('cta-section');
    const ctaBubble = document.getElementById('cta-bubble');
    const ctaBg = document.getElementById('cta-bg');

    if (ctaSection && ctaBubble && ctaBg) {
        let ticking = false;

        ctaSection.addEventListener('mousemove', (e) => {
            if (!ticking) {
                window.requestAnimationFrame(() => {
                    const rect = ctaSection.getBoundingClientRect();
                    const x = e.clientX - rect.left;
                    const y = e.clientY - rect.top;
                    
                    // Calculate center
                    const centerX = rect.width / 2;
                    const centerY = rect.height / 2;
                    
                    // Calculate rotation (max 10 degrees)
                    const rotateX = ((y - centerY) / centerY) * -10;
                    const rotateY = ((x - centerX) / centerX) * 10;
                    
                    // Apply rotation to bubble
                    ctaBubble.style.transform = `perspective(1000px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) scale3d(1.02, 1.02, 1.02)`;
                    
                    // Move background in opposite direction (parallax)
                    const moveX = ((x - centerX) / centerX) * -20;
                    const moveY = ((y - centerY) / centerY) * -20;
                    
                    ctaBg.style.transform = `translate(calc(-50% + ${moveX}px), calc(-50% + ${moveY}px)) scale(1.1)`;
                    
                    ticking = false;
                });
                ticking = true;
            }
        });
        
        // Reset on mouse leave
        ctaSection.addEventListener('mouseleave', () => {
            ctaBubble.style.transform = 'perspective(1000px) rotateX(0) rotateY(0) scale3d(1, 1, 1) rotate(1deg)'; // Keep original slight rotation
            ctaBg.style.transform = 'translate(-50%, -50%) scale(1)';
        });
    }

    /* --- PROFILE FESTIVE CLICK EFFECT --- */
    const profileTrigger = document.getElementById('profile-trigger');
    
    if (profileTrigger) {
        profileTrigger.addEventListener('click', (e) => {
            // 1. Shake Effect (using existing hover-shake animation concept)
            // We'll manually inject a keyframe animation or toggle a class if defined.
            // Since we don't have a specific "shake on command" class, let's use a temporary inline style or forced class.
            // But better, let's just trigger the confetti/pops which is the main "festive" part.
            
            // 2. Spawn Comic Pops
            const rect = profileTrigger.getBoundingClientRect();
            // Center of the image
            const centerX = rect.left + rect.width / 2;
            const centerY = rect.top + rect.height / 2;
            
            const festiveWords = ["WOW!", "COOL!", "EPIC!", "DEV!", "HIRE!", "CODE!", "MAGIC!", "YOO!", "SICK!", "RAD!"];
            const festiveShapes = ["shape-burst", "shape-star", "shape-zap"]; // Only the "loud" shapes
            
            let count = 0;
            const maxPops = 15;
            
            const interval = setInterval(() => {
                count++;
                if (count > maxPops) {
                    clearInterval(interval);
                    return;
                }
                
                const pop = document.createElement('div');
                pop.classList.add('click-pop');
                
                // Random word & shape
                pop.innerText = festiveWords[Math.floor(Math.random() * festiveWords.length)];
                pop.classList.add(festiveShapes[Math.floor(Math.random() * festiveShapes.length)]);
                
                // Random position AROUND the center (not exactly at cursor)
                // Spread: +/- 150px
                const offsetX = (Math.random() - 0.5) * 300; 
                const offsetY = (Math.random() - 0.5) * 300;
                
                pop.style.left = `${centerX + offsetX}px`;
                pop.style.top = `${centerY + offsetY}px`;
                
                // Random rotation
                const rotation = Math.random() * 60 - 30;
                pop.style.setProperty('--rotation', `${rotation}deg`);
                
                // Random scale (bigger than usual)
                const scale = 1.0 + Math.random() * 0.8;
                pop.style.fontSize = `${2.5 * scale}rem`;
                
                // Higher Z-index for festive mode
                pop.style.zIndex = "10000";
                
                document.body.appendChild(pop);
                
                setTimeout(() => {
                    pop.remove();
                }, 800); // Slightly longer life
                
            }, 100); // Spawn every 100ms
        });
    }
  </script>
</BaseLayout>
